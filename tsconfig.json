{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",

    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": "./src",

    "paths": {
      "*": ["*"]
    },

    "moduleResolution": "node",

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "strict": false,

    "skipLibCheck": true
  },

  "include": ["src/**/*.ts"],

  "exclude": ["node_modules"]
}
